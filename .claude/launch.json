{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "elarion-website",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "website", "run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "billing-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "samples/Billing/web", "run", "dev"],
      "port": 5173
    },
    {
      "name": "livequotes",
      "runtimeExecutable": "dotnet",
      "runtimeArgs": ["run", "--project", "samples/LiveQuotes/LiveQuotes.Api", "-c", "Release", "--no-build"],
      "port": 5210
    }
  ]
}

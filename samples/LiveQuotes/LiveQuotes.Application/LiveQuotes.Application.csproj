<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>LiveQuotes sample — the Market module: the quote actors, the (simulated) feed, the client-event contract, and the query handlers. A separate assembly deliberately: the host's generated bootstrapper composes modules from referenced assemblies' manifests, so module code lives beside the module, web-free.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Elarion\Elarion.csproj" />
    <ProjectReference Include="..\..\..\src\Elarion.Actors\Elarion.Actors.csproj" />
    <ProjectReference Include="..\..\..\src\Elarion.ClientEvents\Elarion.ClientEvents.csproj" />
  </ItemGroup>

  <!-- Building from source, the generators are referenced as analyzers (consuming Elarion from NuGet
       they ship bundled in the Elarion package): handlers, actors, and the client-event topic are all
       generated from the attributes in this assembly and published through its manifest. -->
  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Elarion.Generators\Elarion.Generators.csproj"
                     OutputItemType="Analyzer"
                     ReferenceOutputAssembly="false" />
  </ItemGroup>

</Project>

<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <Description>EdgeTelemetry sample — the Elarion EF-free NativeAOT tier end-to-end: a telemetry ingest node published as a native binary (fast cold start, small footprint), with ADR-0057 SQL migrations as the schema half and ADR-0058 generated row mappers as the access half. No EF, no reflection, no runtime code generation.</Description>
    <PublishAot>true</PublishAot>
    <InvariantGlobalization>true</InvariantGlobalization>
    <EnableRequestDelegateGenerator>true</EnableRequestDelegateGenerator>
  </PropertyGroup>

  <!-- Deliberately the OTHER data tier from samples/Billing and samples/LiveQuotes: no EF Core —
       a single process built for cold-start speed (edge nodes, scale-to-zero, CLI-style lifetimes).
       The programming model stays the same as every Elarion app ([Handler] classes registered by the
       generated module bootstrapper); the two AOT-tier packages carry the whole data story:
         Elarion.Migrations            — embedded V__ scripts applied before the host reports ready;
         Elarion.Sql                   — [SqlRecord] generated mappers + injection-safe interpolation;
         Elarion.Sql.PostgreSql        — the single AddElarionPostgreSql picks the provider for both.
       Everything else is the stock slim builder. -->
  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Elarion\Elarion.csproj"/>
    <ProjectReference Include="..\..\..\src\Elarion.AspNetCore\Elarion.AspNetCore.csproj"/>
    <ProjectReference Include="..\..\..\src\Elarion.Sql\Elarion.Sql.csproj"/>
    <ProjectReference Include="..\..\..\src\Elarion.Sql.PostgreSql\Elarion.Sql.PostgreSql.csproj"/>
    <ProjectReference Include="..\..\..\src\Elarion.Migrations\Elarion.Migrations.csproj"/>
  </ItemGroup>

  <!-- Observability for the Aspire dashboard (OTLP). The whole pipeline only activates when an OTLP
       endpoint is configured, so the bare edge binary stays lean. -->
  <ItemGroup>
    <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol"/>
    <PackageReference Include="OpenTelemetry.Extensions.Hosting"/>
    <PackageReference Include="OpenTelemetry.Instrumentation.AspNetCore"/>
  </ItemGroup>

  <!-- The generators as analyzers (building from source; from NuGet they ship inside their packages):
       Elarion.Generators emits the module bootstrapper + handler registrations, Elarion.Sql.Generators
       the row mappers. -->
  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Elarion.Generators\Elarion.Generators.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false"/>
    <ProjectReference Include="..\..\..\src\Elarion.Sql.Generators\Elarion.Sql.Generators.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false"/>
  </ItemGroup>

  <!-- Migration scripts are embedded resources: discovery reads the assembly manifest — AOT-safe,
       no filesystem layout to ship next to the binary. -->
  <ItemGroup>
    <EmbeddedResource Include="Migrations/**/*.sql"/>
  </ItemGroup>

</Project>

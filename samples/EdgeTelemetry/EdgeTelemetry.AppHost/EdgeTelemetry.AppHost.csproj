<Project Sdk="Microsoft.NET.Sdk">

  <Sdk Name="Aspire.AppHost.Sdk" Version="13.4.6" />

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <IsAspireHost>true</IsAspireHost>
    <Description>EdgeTelemetry sample — .NET Aspire orchestration: provisions TimescaleDB and runs the API.</Description>
    <!-- The repo default (Directory.Build.props) disables reflection-based JSON for framework/AOT
         hygiene, but Aspire.Hosting's orchestrator (DCP dependency check) deserializes with
         reflection — the AppHost is dev orchestration tooling, so turn it back on here. -->
    <JsonSerializerIsReflectionEnabledByDefault>true</JsonSerializerIsReflectionEnabledByDefault>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Aspire.Hosting.AppHost" />
    <PackageReference Include="Aspire.Hosting.PostgreSQL" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\EdgeTelemetry.Api\EdgeTelemetry.Api.csproj" />
  </ItemGroup>

</Project>

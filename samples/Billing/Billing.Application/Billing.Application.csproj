<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>Billing sample — shared-kernel entities, modules, handlers, and the generated data-access context.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Elarion\Elarion.csproj" />
    <ProjectReference Include="..\..\..\src\Elarion.EntityFrameworkCore\Elarion.EntityFrameworkCore.csproj" />
  </ItemGroup>

  <!-- Building from source, the generators are referenced as analyzers (consuming Elarion from NuGet
       they ship bundled in the Elarion / Elarion.EntityFrameworkCore packages). The EF Core generator
       must be present here because this assembly declares the [EntityConfiguration] types (the module
       configs that drive the shared-kernel entities under Billing.Application.Domain) — the marker package
       alone would emit no configuration manifest or DbSets. -->
  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Elarion.Generators\Elarion.Generators.csproj"
                     OutputItemType="Analyzer"
                     ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\..\..\src\Elarion.EntityFrameworkCore.Generators\Elarion.EntityFrameworkCore.Generators.csproj"
                     OutputItemType="Analyzer"
                     ReferenceOutputAssembly="false" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Relational" />
    <PackageReference Include="FluentValidation" />
  </ItemGroup>

</Project>

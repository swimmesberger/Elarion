{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "JSON-RPC 2.0 Schema",
  "methods": {
    "clients.create": {
      "params": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "The client\u0027s display name.",
            "minLength": 1,
            "maxLength": 200
          },
          "email": {
            "type": "string",
            "description": "The client\u0027s billing email address.",
            "format": "email",
            "maxLength": 320
          }
        },
        "required": [
          "name",
          "email"
        ]
      },
      "result": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "number": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "number"
        ]
      }
    },
    "clients.get": {
      "params": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          }
        },
        "required": [
          "id"
        ]
      },
      "result": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "number": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "number",
          "name",
          "email"
        ]
      }
    },
    "clients.list": {
      "params": {
        "type": "object"
      },
      "result": {
        "type": "object",
        "properties": {
          "clients": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "format": "uuid"
                },
                "number": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "email": {
                  "type": "string"
                }
              },
              "required": [
                "id",
                "number",
                "name",
                "email"
              ]
            }
          }
        },
        "required": [
          "clients"
        ]
      }
    },
    "invoices.create": {
      "params": {
        "type": "object",
        "properties": {
          "clientId": {
            "type": "string",
            "format": "uuid"
          },
          "amountCents": {
            "type": "integer",
            "description": "Invoice total in minor units, e.g. 1999 = \u20AC19.99.",
            "minimum": 1
          },
          "currency": {
            "type": "string",
            "minLength": 3,
            "maxLength": 3
          },
          "dueDate": {
            "type": "string",
            "format": "date"
          }
        },
        "required": [
          "clientId",
          "amountCents",
          "currency",
          "dueDate"
        ]
      },
      "result": {
        "type": "object",
        "properties": {
          "invoiceId": {
            "type": "string",
            "format": "uuid"
          },
          "number": {
            "type": "string"
          },
          "sendJobId": {
            "type": "string",
            "format": "uuid"
          }
        },
        "required": [
          "invoiceId",
          "number",
          "sendJobId"
        ]
      }
    },
    "invoices.list": {
      "params": {
        "type": "object"
      },
      "result": {
        "type": "object",
        "properties": {
          "invoices": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "format": "uuid"
                },
                "number": {
                  "type": "string"
                },
                "amountCents": {
                  "type": "integer"
                },
                "currency": {
                  "type": "string"
                },
                "status": {
                  "type": "string"
                },
                "dueDate": {
                  "type": "string",
                  "format": "date"
                }
              },
              "required": [
                "id",
                "number",
                "amountCents",
                "currency",
                "status",
                "dueDate"
              ]
            }
          }
        },
        "required": [
          "invoices"
        ]
      }
    },
    "invoices.sendStatus": {
      "params": {
        "type": "object",
        "properties": {
          "jobId": {
            "type": "string",
            "format": "uuid"
          }
        },
        "required": [
          "jobId"
        ]
      },
      "result": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "attempt": {
            "type": "integer"
          },
          "maxAttempts": {
            "type": "integer"
          },
          "nextAttemptAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "lastError": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "status",
          "attempt",
          "maxAttempts",
          "nextAttemptAt",
          "lastError"
        ]
      }
    }
  }
}
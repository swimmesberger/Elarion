{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Scheduler": {
    "Enabled": true,
    "MaxConcurrentExecutions": 8
  },
  "Modules": {
    "Clients": { "Enabled": true },
    "Invoicing": { "Enabled": true }
  }
}

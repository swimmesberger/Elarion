<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <Description>Billing sample — ASP.NET Core host: JSON-RPC, MCP, scheduler/resilience/cache runtimes, telemetry.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Elarion\Elarion.csproj" />
    <ProjectReference Include="..\..\..\src\Elarion.JsonRpc\Elarion.JsonRpc.csproj" />
    <ProjectReference Include="..\..\..\src\Elarion.AspNetCore\Elarion.AspNetCore.csproj" />
    <ProjectReference Include="..\..\..\src\Elarion.AspNetCore.Mcp\Elarion.AspNetCore.Mcp.csproj" />
    <ProjectReference Include="..\..\..\src\Elarion.Messaging.Outbox\Elarion.Messaging.Outbox.csproj" />
    <ProjectReference Include="..\..\..\src\Elarion.EntityFrameworkCore.UnitOfWork\Elarion.EntityFrameworkCore.UnitOfWork.csproj" />
    <ProjectReference Include="..\..\..\src\Elarion.Caching\Elarion.Caching.csproj" />
    <ProjectReference Include="..\..\..\src\Elarion.Resilience\Elarion.Resilience.csproj" />
    <ProjectReference Include="..\Billing.Application\Billing.Application.csproj" />
    <ProjectReference Include="..\Billing.Infrastructure\Billing.Infrastructure.csproj" />
  </ItemGroup>

  <!-- The host runs the Elarion generator to emit the module bootstrapper (RPC/HTTP/MCP maps,
       ConfigureAllServices). Building from source we reference the generator project as an analyzer. -->
  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Elarion.Generators\Elarion.Generators.csproj"
                     OutputItemType="Analyzer"
                     ReferenceOutputAssembly="false" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" />
    <PackageReference Include="OpenTelemetry.Extensions.Hosting" />
    <PackageReference Include="OpenTelemetry.Instrumentation.AspNetCore" />
    <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol" />
  </ItemGroup>

</Project>

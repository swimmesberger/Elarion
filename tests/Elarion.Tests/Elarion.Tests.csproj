  </ItemGroup>
  <ItemGroup>
    <!-- Migration-runner test scripts: the runner discovers embedded .sql resources, scoped per scenario
         by resource-name prefix. PostgreSQL and SQLite scenarios live in separate script trees. -->
    <EmbeddedResource Include="Migrations/Scripts/**/*.sql"/>
    <EmbeddedResource Include="Migrations/SqliteScripts/**/*.sql"/>
  </ItemGroup>
  <ItemGroup>
    <!-- Long-running-test detection: with diagnostics on, the runner names any test exceeding the
         threshold — a hanging test is identified instead of silently stalling the whole run. -->
    <None Include="xunit.runner.json" CopyToOutputDirectory="PreserveNewest"/>
  </ItemGroup>

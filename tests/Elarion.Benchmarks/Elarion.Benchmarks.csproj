<Project Sdk="Microsoft.NET.Sdk">

  <!-- Micro-benchmarks for framework hot paths (currently the Elarion.Actors call path).
       Results gate the ADR-0042 optimization roadmap; run instructions are in Program.cs. -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <ServerGarbageCollection>true</ServerGarbageCollection>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BenchmarkDotNet" />
    <!-- Cross-platform profiling (opt-in via the "profiler DT" CLI switch, macOS-friendly): auto-downloads
         the JetBrains dotTrace CLI on first run and emits a .dtt snapshot. The speedscope/flamegraph path
         (the "profiler EP" switch) needs no package; EventPipeProfiler ships in the core package. See Program.cs. -->
    <PackageReference Include="BenchmarkDotNet.Diagnostics.dotTrace" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/Elarion.Actors/Elarion.Actors.csproj" />
  </ItemGroup>

</Project>

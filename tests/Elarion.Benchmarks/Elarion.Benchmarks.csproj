<Project Sdk="Microsoft.NET.Sdk">

  <!-- Micro-benchmarks for framework hot paths (currently the Elarion.Actors call path).
       Results gate the ADR-0042 optimization roadmap; run instructions are in Program.cs. -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <ServerGarbageCollection>true</ServerGarbageCollection>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BenchmarkDotNet" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/Elarion.Actors/Elarion.Actors.csproj" />
  </ItemGroup>

</Project>

<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>Device identity and provisioning for Elarion (ADR-0054): single-use pairing codes (CSPRNG, human-typeable alphabet, TTL) redeemed for a per-device symmetric key, the IDeviceKeyStore/IPairingCodeStore seams, a constant-time HMAC challenge verifier shaped for connection-handshake authenticators, and the device ClaimsPrincipal factory.</Description>
    <IsAotCompatible>true</IsAotCompatible>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions"/>
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Elarion.Tests"/>
  </ItemGroup>

</Project>

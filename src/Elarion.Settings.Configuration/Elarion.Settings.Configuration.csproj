<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>IConfiguration adapter for Elarion settings: surfaces global settings as an IConfiguration provider with IChangeToken reload (so IOptionsMonitor and the scheduler's variable substitution pick up runtime changes), over any ISettingsStore backend.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Elarion.Settings\Elarion.Settings.csproj"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Configuration"/>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions"/>
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions"/>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions"/>
  </ItemGroup>

</Project>

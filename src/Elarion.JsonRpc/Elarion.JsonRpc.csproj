<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>Transport-neutral JSON-RPC dispatcher, envelopes, result types, schema export, telemetry, and source-generation triggers for Elarion.</Description>
    <PackageTags>elarion;json-rpc;schema;dotnet</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <!-- Abstractions: the JSON-RPC transport bridges Elarion handlers (IHandler/Result/AppError) onto the
         dispatcher (MapHandler, AppErrorMapper) and uses the dispatch-scope rail. -->
    <ProjectReference Include="..\Elarion.Abstractions\Elarion.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- DI.Abstractions: RpcToolInvoker owns the per-call service scope (CreateAsyncScope). -->
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
  </ItemGroup>

</Project>

<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>Transport-neutral JSON-RPC dispatcher, envelopes, result types, schema export, telemetry, and source-generation triggers for Elarion.</Description>
    <PackageTags>elarion;json-rpc;schema;dotnet</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <!-- DI.Abstractions: RpcToolInvoker owns the per-call service scope (CreateAsyncScope). -->

<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>Transport-neutral JSON-RPC dispatcher, envelopes, result types, schema export, telemetry, and source-generation triggers for Elarion.</Description>
    <PackageTags>elarion;json-rpc;schema;dotnet</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <!-- Abstractions: the JSON-RPC/MCP adapters serve the shared HandlerDispatcher bus, map Result/AppError to the
         wire (AppErrorMapper), and use the dispatch-scope rail. -->
    <ProjectReference Include="..\Elarion.Abstractions\Elarion.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- DI.Abstractions: RpcToolInvoker owns the per-call service scope (CreateAsyncScope). -->
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
  </ItemGroup>

</Project>

<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>PostgreSQL LISTEN/NOTIFY change source for Elarion settings: a settings write on one node fires IChangeToken watchers on every node, and a write inside a transaction is notified only on commit (NOTIFY is transactional). The multi-instance companion to the EF Core settings store.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Elarion.Settings\Elarion.Settings.csproj"/>
    <ProjectReference Include="..\Elarion.Settings.EntityFrameworkCore\Elarion.Settings.EntityFrameworkCore.csproj"/>
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Elarion.Tests"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Npgsql"/>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions"/>
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions"/>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions"/>
  </ItemGroup>

</Project>

<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>EF Core database backend for Elarion settings: a relational, provider-neutral ISettingsStore with optimistic concurrency, reusing the in-process change source for in-process change notification.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Elarion.Settings\Elarion.Settings.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Elarion.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Relational" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
  </ItemGroup>

  <!-- Bundle the Settings source generator's analyzer into this package. NuGet analyzer assets are not
       transitive, so the generator lives in the package each annotated assembly references directly.
       ReferenceOutputAssembly=false keeps it off the runtime surface; PrivateAssets=all keeps it from
       becoming a downstream package dependency. -->
  <ItemGroup>
    <ProjectReference Include="..\Elarion.Settings.EntityFrameworkCore.Generators\Elarion.Settings.EntityFrameworkCore.Generators.csproj"
                     ReferenceOutputAssembly="false"
                     PrivateAssets="all" />
  </ItemGroup>

  <Target Name="_BundleElarionSettingsGenerator" BeforeTargets="_GetPackageFiles">
    <MSBuild Projects="..\Elarion.Settings.EntityFrameworkCore.Generators\Elarion.Settings.EntityFrameworkCore.Generators.csproj"
             Targets="GetTargetPath">
      <Output TaskParameter="TargetOutputs" ItemName="_ElarionSettingsGeneratorAnalyzer" />
    </MSBuild>
    <ItemGroup>
      <None Include="@(_ElarionSettingsGeneratorAnalyzer)"
            Pack="true"
            PackagePath="analyzers/dotnet/cs/"
            Visible="false" />
    </ItemGroup>
  </Target>

</Project>


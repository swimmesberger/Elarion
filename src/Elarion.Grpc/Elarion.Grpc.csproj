<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>Typed unary and request-driven server-streaming gRPC transport adapter for Elarion handlers: explicit wire mapping, dispatch-scope seeding, and AppError to RpcException translation without a hosting dependency.</Description>
    <PackageTags>elarion;grpc;transport;handler-pipeline;dotnet</PackageTags>
    <IsAotCompatible>true</IsAotCompatible>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Elarion\Elarion.csproj"/>
    <ProjectReference Include="..\Elarion.Abstractions\Elarion.Abstractions.csproj"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Grpc.Core.Api"/>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions"/>
  </ItemGroup>

</Project>

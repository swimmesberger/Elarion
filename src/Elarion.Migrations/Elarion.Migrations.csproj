<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>Database-neutral SQL migration engine for EF-free (NativeAOT) Elarion hosts (ADR-0060): embedded V{version}__/R__ script discovery, SHA-256 checksums over line-ending-normalized content, out-of-order and repeatable planning, and the roll-forward execution model (history rows commit with their script — no repair command, no failed-row limbo). Drives a database provider through the IMigrationDatabase seam; a provider package (Elarion.Migrations.PostgreSql, Elarion.Migrations.Sqlite) supplies the SQL and locking. Contains no database driver.</Description>
    <IsAotCompatible>true</IsAotCompatible>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions"/>
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions"/>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions"/>
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Elarion.Migrations.PostgreSql"/>
    <InternalsVisibleTo Include="Elarion.Migrations.Sqlite"/>
    <InternalsVisibleTo Include="Elarion.Tests"/>
  </ItemGroup>

</Project>

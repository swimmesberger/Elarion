<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>Opinionated application primitives for module-based handler pipelines.</Description>
    <!-- Enables the trim + Native AOT analyzers so reflection that breaks AOT is a build warning here, not a
         surprise in a consuming app. Core is transport-/EF-free and must stay AOT-clean. -->
    <IsAotCompatible>true</IsAotCompatible>
  </PropertyGroup>

  <ItemGroup>
    <!-- Transport-agnostic: core depends only on Abstractions. The JSON-RPC transport (Elarion.JsonRpc) is a
         sibling that references Abstractions too; core does not reference any transport. -->
    <ProjectReference Include="..\Elarion.Abstractions\Elarion.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Caching.Hybrid" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Resilience" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Elarion.Messaging.InMemory" />
  </ItemGroup>

  <!-- Bundle the Elarion source generator's analyzer into this runtime package. NuGet analyzer assets
       are not transitive, so the generator must live in a package each code-generating assembly
       references directly. Elarion is that single home: application libraries reference it for the
       runtime, and hosts reference it directly too (they already depend on it transitively via
       Elarion.AspNetCore). Keeping the generator in exactly one package avoids it running twice.
       ReferenceOutputAssembly=false keeps it off the runtime surface; PrivateAssets=all keeps it from
       becoming a downstream package dependency. -->
  <ItemGroup>
    <ProjectReference Include="..\Elarion.Generators\Elarion.Generators.csproj"
                     ReferenceOutputAssembly="false"
                     PrivateAssets="all" />
  </ItemGroup>

  <Target Name="_BundleElarionGenerator" BeforeTargets="_GetPackageFiles">
    <MSBuild Projects="..\Elarion.Generators\Elarion.Generators.csproj"
             Targets="GetTargetPath">
      <Output TaskParameter="TargetOutputs" ItemName="_ElarionGeneratorAnalyzer" />
    </MSBuild>
    <ItemGroup>
      <None Include="@(_ElarionGeneratorAnalyzer)"
            Pack="true"
            PackagePath="analyzers/dotnet/cs/"
            Visible="false" />
    </ItemGroup>
  </Target>

</Project>

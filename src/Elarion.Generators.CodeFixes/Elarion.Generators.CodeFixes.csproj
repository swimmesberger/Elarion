<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>Code fixes for Elarion's analyzers (bundled into the Elarion runtime package).</Description>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <IncludeSymbols>false</IncludeSymbols>
    <DevelopmentDependency>true</DevelopmentDependency>
    <NoPackageAnalysis>true</NoPackageAnalysis>
    <!-- Code fixes are Workspaces-layer components, so they live in their own assembly: the compiler loads
         analyzer/generator assemblies without Microsoft.CodeAnalysis.Workspaces on the load path (RS1038),
         while the IDE loads this sibling from the same analyzers/dotnet/cs folder. Bundled into the Elarion
         package next to Elarion.Generators — never shipped as its own NuGet package. -->
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" PrivateAssets="all" />
  </ItemGroup>

</Project>

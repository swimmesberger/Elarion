<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>EF Core transactional outbox for Elarion integration events: events are recorded in the caller's unit of work and delivered durably after commit through IIntegrationEventBus.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Elarion.Abstractions\Elarion.Abstractions.csproj" />
    <!-- The inbox (ADR-0022) is default-on for handler-form integration consumers, so the delivery tier wires the
         idempotency building blocks (AddElarionIdempotency lives in the core runtime package). -->
    <ProjectReference Include="..\Elarion\Elarion.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Relational" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
  </ItemGroup>

  <!-- Bundle the Outbox source generator's analyzer into this package. NuGet analyzer assets are not
       transitive, so the generator lives in the package each annotated assembly references directly.
       ReferenceOutputAssembly=false keeps it off the runtime surface; PrivateAssets=all keeps it from
       becoming a downstream package dependency. -->
  <ItemGroup>
    <ProjectReference Include="..\Elarion.Messaging.Outbox.Generators\Elarion.Messaging.Outbox.Generators.csproj"
                     ReferenceOutputAssembly="false"
                     PrivateAssets="all" />
  </ItemGroup>

  <Target Name="_BundleElarionOutboxGenerator" BeforeTargets="_GetPackageFiles">
    <MSBuild Projects="..\Elarion.Messaging.Outbox.Generators\Elarion.Messaging.Outbox.Generators.csproj"
             Targets="GetTargetPath">
      <Output TaskParameter="TargetOutputs" ItemName="_ElarionOutboxGeneratorAnalyzer" />
    </MSBuild>
    <ItemGroup>
      <None Include="@(_ElarionOutboxGeneratorAnalyzer)"
            Pack="true"
            PackagePath="analyzers/dotnet/cs/"
            Visible="false" />
    </ItemGroup>
  </Target>

</Project>


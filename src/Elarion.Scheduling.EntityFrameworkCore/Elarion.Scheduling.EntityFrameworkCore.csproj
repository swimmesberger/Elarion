<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>Cross-instance scheduler coordination for Elarion over EF Core/PostgreSQL: unique-constrained per-occurrence claim rows make each recurring job occurrence execute on exactly one node, with the [GenerateElarionSchedulerClaims] DbSet generator and a claim-retention purge worker. Targets PostgreSQL.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Elarion.Abstractions\Elarion.Abstractions.csproj"/>
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Elarion.Tests"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Relational"/>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions"/>
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions"/>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions"/>
  </ItemGroup>

  <!-- Bundle the scheduler-claims source generator's analyzer into this package. NuGet analyzer assets are not
       transitive, so the generator lives in the package each annotated assembly references directly.
       ReferenceOutputAssembly=false keeps it off the runtime surface; PrivateAssets=all keeps it from
       becoming a downstream package dependency. -->
  <ItemGroup>
    <ProjectReference Include="..\Elarion.Scheduling.EntityFrameworkCore.Generators\Elarion.Scheduling.EntityFrameworkCore.Generators.csproj"
                      ReferenceOutputAssembly="false"
                      PrivateAssets="all"/>
  </ItemGroup>

  <Target Name="_BundleElarionSchedulerClaimsGenerator" BeforeTargets="_GetPackageFiles">
    <MSBuild Projects="..\Elarion.Scheduling.EntityFrameworkCore.Generators\Elarion.Scheduling.EntityFrameworkCore.Generators.csproj"
             Targets="GetTargetPath">
      <Output TaskParameter="TargetOutputs" ItemName="_ElarionSchedulerClaimsGeneratorAnalyzer"/>
    </MSBuild>
    <ItemGroup>
      <None Include="@(_ElarionSchedulerClaimsGeneratorAnalyzer)"
            Pack="true"
            PackagePath="analyzers/dotnet/cs/"
            Visible="false"/>
    </ItemGroup>
  </Target>

</Project>

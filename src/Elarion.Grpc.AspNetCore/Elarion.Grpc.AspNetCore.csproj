<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>ASP.NET Core grpc-dotnet conventions for Elarion unary and request-driven server-streaming handlers: host composition, authenticated principal capture, and ServerCallContext invocation.</Description>
    <PackageTags>elarion;grpc;aspnetcore;transport;handler-pipeline;dotnet</PackageTags>
    <IsAotCompatible>true</IsAotCompatible>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Elarion.Grpc\Elarion.Grpc.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Grpc.AspNetCore.Server" />
  </ItemGroup>

</Project>
